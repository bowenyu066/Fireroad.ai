rest_electives

cims


%% Departmental Program
math_intro, "Mathematics and Introductory" := (6.100A/6.100L/6.1020), 6.120A, 6.C06
chem, "Chemistry" := 5.12, 5.601
intro_lab, "Introductory Laboratory" := (7.002, 7.003)/20.109
foundational_subjects, "Foundational Subjects" := comp_foundation, bio_foundation

comp_foundation, "Computer Science Foundational" := 6.1010, 6.1210, (6.3900/(6.C01, 7.C01))
bio_foundation, "Biological Science Foundational" := 7.03, (7.05/5.07), 7.06

reqd_subjects, "Required Subjects" := math_intro, chem, intro_lab, foundational_subjects

comp_bio_rest, "Computational Biology" := 1.088/18.413/6.4710/6.8701/(7.093, 7.094)/7.032/7.033
comms, "Technical Communication" := 6.UAT/6.UAR/7.19

