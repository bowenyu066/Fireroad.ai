comp_bio_other, "Computational Biology" := 1.088/18.413/6.4710/6.8701/(7.093, 7.094)/7.032/7.033
other_rest, "Two additional Restricted Elective subjects" := bio_rest, aid_aus, comp_bio_other{>=3}

rest_electives, "Restricted Electives" := comp_bio_rest, comms, other_rest

cims, "Communication-Intensive Subjects" := (7.002,7.003)/20.109/6.UAR/6.UAT/7.19{>=2}