rest_elec, "Restricted Electives" := 7.08/7.09/7.20/7.21/7.22/7.23/7.26/7.27/7.28/7.29/(7.30A,7.30B)/7.31/7.32/7.33/(7.37/7.371)/7.41/7.45/7.49/9.15/9.17{>=3}

