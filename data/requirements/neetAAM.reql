proj_1, "Intro Project" := 3.007/22.03
proj_2, "Intermediate Project" := 2.008
urop := ""UROP in materials and manufacturing""{>=1}
capstone, "Capstone" := 3.042/2.013/2.014/2.S981/urop{>=2}
seminar, "Seminar" := ""3 semesters of 3.006""{>=3}
foundation, "Suggested Foundations" := 3.012/2.001/3.044/3.032/2.005/(2.001, 2.002){>=0}