{
  "name": "fireroad-ai-prototype",
  "version": "0.1.0",
  "private": true,
  "description": "Static Fireroad.ai prototype with a tiny OpenRouter-backed course-planning agent server.",
  "main": "server.js",
  "scripts": {
    "dev": "npm run history:setup && node server.js",
    "history:init": "node scripts/history/init_db.mjs",
    "history:seed": "node scripts/history/seed_history_courses.mjs",
    "history:import-manifest": "node scripts/history/import_offering_manifest.mjs",
    "history:fetch-docs": "node scripts/history/fetch_documents.mjs",
    "history:extract-policies": "node scripts/history/extract_policies.mjs",
    "history:collect": "node scripts/history/collect_course_history.mjs",
    "history:research": "node scripts/history/research_course_history.mjs",
    "history:research-selected": "node scripts/history/research_selected_courses.mjs",
    "history:ablate-markdown": "node scripts/history/ablate_offering_markdown.mjs",
    "history:rewrite-markdown": "node scripts/history/rewrite_offering_markdown.mjs",
    "history:setup": "npm run history:init && npm run history:seed",
    "start": "npm run history:setup && node server.js"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "better-sqlite3": "^12.9.0",
    "dotenv": "^17.4.2",
    "express": "^4.18.3",
    "multer": "^2.1.1",
    "pdf-parse": "^1.1.1"
  }
}
